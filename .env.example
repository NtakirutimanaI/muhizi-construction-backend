# Application
NODE_ENV=development
PORT=3000
APP_NAME=MUHIZI CONSTRUCTION Backend

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
